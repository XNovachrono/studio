rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles and ownership
    function isSignedIn() {
      return request.auth != null;
    }

    function isStudent() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can read all user profiles
      // Teachers can read student profiles
      // Users can read their own profile
      allow read: if isSignedIn() && (isAdmin() || (isTeacher() && get(/databases/$(database)/documents/users/$(userId)).data.role == 'student') || request.auth.uid == userId);
      
      // Users can update their own profile
      // Admins can update any user profile
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Only admins can create or delete users through the console/backend
      allow create, delete: if isAdmin();
    }

    // Rules for the 'groups' collection
    match /groups/{groupId} {
      // Authenticated users can read groups. The app logic filters which ones they see.
      allow read: if isSignedIn();
      
      // Only admins and the assigned teacher can update a group
      allow update: if isSignedIn() && (isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid));
      
      // Only admins can create or delete groups
      allow create, delete: if isSignedIn() && isAdmin();

      // Subcollection for lessons within a group
      match /lessons/{lessonId} {
        // Admins, the assigned teacher, or a student in the group can read lessons
        allow read: if isSignedIn() && (isAdmin() || (isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid) || (isStudent() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds));
        
        // Only admins or the assigned teacher can create/update/delete lessons
        allow write: if isSignedIn() && (isAdmin() || (isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid));
      }
    }

    // Rules for 'bank_cards' collection (reusable content)
    match /bank_cards/{cardId} {
        // Users can read their own bank cards. Admins can read all.
        allow read: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
        
        // Users can create/update/delete their own bank cards.
        allow write: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }
    
    // Rules for 'pqrs' collection (requests/complaints)
    match /pqrs/{pqrsId} {
        // Only students can create PQRS messages
        allow create: if isSignedIn() && isStudent();

        // Reading/deleting PQRS is likely an admin/teacher task from the backend/console
        allow read, update, delete: if isSignedIn() && (isTeacher() || isAdmin());
    }
  }
}
