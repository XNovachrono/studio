rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile and admins can read any profile.
    // Users can only update their own profile.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if request.auth.uid == userId;
    }

    // Admins can read all groups.
    // Teachers and students can read groups they are a part of.
    // Only the teacher of the group or an admin can update it.
    match /groups/{groupId} {
       allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
                   request.auth.uid == resource.data.teacherId || 
                   request.auth.uid in resource.data.studentIds;
       allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                    request.auth.uid == resource.data.teacherId;

      // Lessons can be read by group members and admins.
      // Lessons can only be created/updated by the group's teacher or an admin.
      match /lessons/{lessonId} {
        allow read: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid ||
                      request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
        allow write: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }

    // PQRS messages can be created by any authenticated user.
    // They can only be read by the involved teacher or an admin.
    match /pqrs/{pqrId} {
      allow create: if request.auth != null;
      allow read: if resource.data.teacherId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Bank cards can be read by any authenticated user (they are templates).
    // They can only be created, updated or deleted by their owner or an admin.
    match /bank_cards/{cardId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if resource.data.ownerId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Students can only manage their own notes.
    match /student_notes/{noteId} {
        allow read, write, delete: if resource.data.studentId == request.auth.uid;
        allow create: if request.resource.data.studentId == request.auth.uid;
    }
  }
}