rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isStudent() {
       return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }
    
    function isGroupMember(groupId) {
      let groupDoc = get(/databases/$(database)/documents/groups/$(groupId));
      return request.auth.uid == groupDoc.data.teacherId || request.auth.uid in groupDoc.data.studentIds;
    }

    // Allow authenticated users to read most top-level collections for app functionality
    match /{collection}/{docId} {
      allow read: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if isOwner(userId); // Users can update their own profile
      allow create, delete: if isAdmin(); // Only admins can create/delete users
    }

    match /groups/{groupId} {
      allow read: if isGroupMember(groupId) || isAdmin();
      allow create: if isAdmin() || isTeacher(); // Teachers can create groups (implicitly via scheduling)
      allow update: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid || isAdmin();
      allow delete: if isAdmin();

      // Lessons are a sub-collection of groups
      match /lessons/{lessonId} {
        allow read: if isGroupMember(groupId);
        allow create, update, delete: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid || isAdmin();
      }
    }

    match /pqrs/{pqrsId} {
      allow read: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow create: if isStudent();
      allow delete: if isAdmin();
    }

    match /bank_cards/{cardId} {
      allow read: if request.auth != null; // All authenticated users can read from banks
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if (isTeacher() && resource.data.ownerId == request.auth.uid) || isAdmin();
    }
    
    match /student_notes/{noteId} {
      allow read, update, delete: if isOwner(resource.data.studentId);
      allow create: if isOwner(request.resource.data.studentId);
    }
  }
}
