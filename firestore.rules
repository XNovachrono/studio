rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read, write: if request.auth != null; 
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
      allow read, write: if request.auth != null;
    }

    match /pqrs/{pqrsId} {
      allow read, write: if request.auth != null;
    }

    match /bank_cards/{cardId} {
      allow read, write: if request.auth != null;
    }

    match /student_notes/{noteId} {
      allow read, get, delete, update: if request.auth.uid == resource.data.studentId;
      allow create: if request.auth.uid == request.resource.data.studentId;
      allow list: if request.query.where.studentId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
