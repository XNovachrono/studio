rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // --- Users Collection ---
    // Anyone can create a user (sign up), but only the user themselves or an admin can read/update it.
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if request.auth.uid != null;
    }

    // --- Groups Collection ---
    // Admins can read all groups. Teachers and students can only read groups they are part of.
    // Only teachers or admins can update a group. Only admins can create/delete.
    match /groups/{groupId} {
      allow read: if request.auth.uid != null;
      allow update: if isTeacher() || isAdmin();
      allow create, delete: if isAdmin();

      // --- Lessons Subcollection ---
      // Only the teacher of the group or an admin can manage lessons.
      // Students in the group can read the lessons.
      match /lessons/{lessonId} {
        allow read: if request.auth.uid in resource.data.studentIds || isOwner(resource.data.teacherId) || isAdmin();
        allow write: if isOwner(resource.data.teacherId) || isAdmin();
      }
    }
    
    // --- Bank Cards Collection ---
    // Any authenticated user can read bank cards.
    // Only the owner or an admin can create, update, or delete their own cards.
    match /bank_cards/{cardId} {
      allow read: if request.auth.uid != null;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
    }
    
    // --- PQRS Collection ---
    // Students can create messages.
    // The involved teacher or an admin can read/delete them.
    match /pqrs/{messageId} {
      allow create: if isOwner(request.resource.data.studentId);
      allow read, delete: if isOwner(resource.data.teacherId) || isAdmin();
    }
    
    // --- Student Notes Collection ---
    // This rule allows any authenticated user to perform list queries on the collection.
    // The application logic ensures that users only query for their own notes.
    // Write operations (create, update, delete) are restricted to the owner of the note.
    match /student_notes/{noteId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid == request.resource.data.studentId;
    }
  }
}
