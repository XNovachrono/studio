
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles
    function isStudent(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'student';
    }

    function isTeacher(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'teacher';
    }

    function isAdmin(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }
    
    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can get their own profile
      allow get: if request.auth != null && request.auth.uid == userId;
      
      // Students can update their own profile
      allow update: if request.auth != null && request.auth.uid == userId && isStudent(request.auth.uid);

      // Teachers can read student profiles
      allow read: if request.auth != null && isTeacher(request.auth.uid) && resource.data.role == 'student';
      
      // Admins can read and write any user profile
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }
    
    // Rules for the 'groups' collection
    match /groups/{groupId} {
        // Any authenticated user can read the list of groups
        allow read: if request.auth != null;

        // Teachers can update groups they are assigned to
        allow update: if request.auth != null && isTeacher(request.auth.uid) && resource.data.teacherId == request.auth.uid;

        // Admins can create, update, and delete groups
        allow create, update, delete: if request.auth != null && isAdmin(request.auth.uid);

        // Subcollection for lessons
        match /lessons/{lessonId} {
            // Authenticated users in the group can read lessons
            allow read: if request.auth != null && request.auth.uid in resource.data.studentIds;
            
            // The teacher of the group can read, create, and update lessons
            allow read, create, update: if request.auth != null && isTeacher(request.auth.uid) && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
            
            // Admins have full access to lessons
            allow read, create, update, delete: if request.auth != null && isAdmin(request.auth.uid);
        }
    }

    // Rules for 'bank_cards' collection (for teachers)
    match /bank_cards/{cardId} {
        // Teachers can create, read, update, delete their own cards
        allow read, write: if request.auth != null && isTeacher(request.auth.uid) && request.resource.data.ownerId == request.auth.uid;
        allow create: if request.auth != null && isTeacher(request.auth.uid) && request.resource.data.ownerId == request.auth.uid;
    }

    // Rules for 'pqrs' collection
    match /pqrs/{pqrsId} {
      // Students can create (submit) PQRS messages
      allow create: if request.auth != null && isStudent(request.auth.uid) && request.resource.data.studentId == request.auth.uid;

      // Admins can read all PQRS messages
      allow read: if request.auth != null && isAdmin(request.auth.uid);
    }
  }
}
