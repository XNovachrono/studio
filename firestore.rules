rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Controls access to group information.
     */
    match /groups/{groupId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isGroupTeacher(groupId);
      allow delete: if isGroupTeacher(groupId);
    }

    /**
     * @description Controls access to lessons within a group.
     */
    match /groups/{groupId}/lessons/{lessonId} {
      allow get: if true;
      allow list: if true;
      allow create: if isGroupTeacher(groupId);
      allow update: if isGroupTeacher(groupId);
      allow delete: if isGroupTeacher(groupId);
    }

    /**
     * @description Controls access to homework submissions for a specific lesson.
     */
    match /groups/{groupId}/lessons/{lessonId}/homework_submissions/{submissionId} {
      allow get: if isGroupTeacher(groupId) || isHomeworkSubmissionOwner(groupId, lessonId, submissionId);
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isGroupTeacher(groupId);
      allow delete: if isGroupTeacher(groupId);
    }

    /**
     * @description Controls access to PQRS messages.
     */
    match /pqrs/{pqrsId} {
      allow get: if isPqrsOwner(pqrsId);
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isPqrsOwner(pqrsId);
      allow delete: if isPqrsOwner(pqrsId);
    }

    /**
     * @description Controls access to student notes.
     */
    match /student_notes/{noteId} {
      allow get: if isStudentNoteOwner(noteId);
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isStudentNoteOwner(noteId);
      allow delete: if isStudentNoteOwner(noteId);
    }

    /**
     * @description Controls access to bank cards.
     */
    match /bank_cards/{cardId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isBankCardOwner(cardId);
      allow delete: if isBankCardOwner(cardId);
    }

    // --- Helper functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isGroupTeacher(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
    }

    function isHomeworkSubmissionOwner(groupId, lessonId, submissionId) {
      return get(/databases/$(database)/documents/groups/$(groupId)/lessons/$(lessonId)/homework_submissions/$(submissionId)).data.studentId == request.auth.uid;
    }

    function isPqrsOwner(pqrsId) {
      return get(/databases/$(database)/documents/pqrs/$(pqrsId)).data.studentId == request.auth.uid;
    }

    function isStudentNoteOwner(noteId) {
      return get(/databases/$(database)/documents/student_notes/$(noteId)).data.studentId == request.auth.uid;
    }

    function isBankCardOwner(cardId) {
      return get(/databases/$(database)/documents/bank_cards/$(cardId)).data.ownerId == request.auth.uid;
    }
  }
}