
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth.uid != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isTeacher();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid);
    }

    match /pqrs/{pqrId} {
      allow read: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /student_notes/{noteId} {
      allow create, update: if request.auth.uid == request.resource.data.studentId;
      allow read, delete: if request.auth.uid == resource.data.studentId;
      allow list: if request.query.where.studentId.value == request.auth.uid;
    }
    
    match /bank_cards/{cardId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isTeacher() && resource.data.ownerId == request.auth.uid || isAdmin();
    }
  }
}
