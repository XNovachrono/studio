
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isTeacher();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      // Only the group's teacher or an admin can modify it
      allow write: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
      allow read: if isSignedIn();
       // Only the group's teacher or an admin can write
      allow write: if isAdmin() || (isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid);
    }

    match /pqrs/{pqrId} {
      allow create: if isOwner(request.resource.data.studentId);
      allow read, delete: if isOwner(request.resource.data.studentId) || isOwner(request.resource.data.teacherId) || isAdmin();
    }
    
    match /student_notes/{noteId} {
      allow create: if isOwner(request.resource.data.studentId);
      allow read, update, delete: if isOwner(resource.data.studentId) || isAdmin();
    }

    match /bank_cards/{cardId} {
        allow read: if isSignedIn();
        allow create: if isOwner(request.resource.data.ownerId);
        allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
    }
  }
}
