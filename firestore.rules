
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Regla de seguridad simple: Solo usuarios autenticados pueden leer y escribir.
    // La lógica de negocio (quién ve qué) se maneja en las consultas de la aplicación.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Regla específica y segura para la colección de bancos.
    // Esto anula la regla general anterior para esta colección específica.
    match /bank_cards/{cardId} {
      // Un usuario puede leer, actualizar o borrar un documento...
      allow read, update, delete: if request.auth != null && 
                                    // ...solo si el 'ownerId' del documento existente coincide con su propio ID.
                                    resource.data.ownerId == request.auth.uid;
      // Un usuario puede crear un nuevo documento...
      allow create: if request.auth != null && 
                      // ...solo si el 'ownerId' del nuevo documento que se está creando coincide con su propio ID.
                      request.resource.data.ownerId == request.auth.uid;
    }
  }
}
