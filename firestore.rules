rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check user role
    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      // Admins can read any user profile
      // Users can read/update their own profile
      allow read, update: if isRole('admin') || request.auth.uid == userId;
    }

    // --- BANK CARDS ---
    match /bank_cards/{cardId} {
        // Admins can read any card
        allow read: if isRole('admin');
        
        // Users can manage their own cards
        allow read, write: if request.auth.uid == resource.data.ownerId; // For update/delete
        allow create: if request.auth.uid == request.resource.data.ownerId; // For create
    }
    
    // --- GROUPS & SUBCOLLECTIONS ---
    match /groups/{groupId} {
    
        // Admins can read any group
        // Teachers can read groups they are assigned to
        // Students can read groups they are a member of
        allow read: if isRole('admin') || 
                      (isRole('teacher') && resource.data.teacherId == request.auth.uid) ||
                      (isRole('student') && request.auth.uid in resource.data.studentIds);
        
        // Admins can create groups
        // Teachers can update groups they are assigned to
        allow write: if isRole('admin') || 
                       (isRole('teacher') && resource.data.teacherId == request.auth.uid);

        // --- LESSONS SUBCOLLECTION ---
        match /lessons/{lessonId} {
            // Permissions inherit from the parent group.
            // If a user can read the group, they can read its lessons.
            // If a user can write to the group, they can write to its lessons.
            allow read, write: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid ||
                                 isRole('admin') ||
                                 (isRole('student') && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds);
        }
    }
  }
}
