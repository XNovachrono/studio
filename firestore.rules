rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check roles
    function isAuth() {
      return request.auth != null;
    }

    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isAdmin() {
      return isAuth() && getUserRole(request.auth.uid) == 'admin';
    }

    function isTeacher() {
      return isAuth() && getUserRole(request.auth.uid) == 'teacher';
    }

    function isStudent() {
      return isAuth() && getUserRole(request.auth.uid) == 'student';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can read any user profile.
      // Users can read and update their own profile.
      allow read: if isAdmin() || request.auth.uid == userId;
      allow update: if isAdmin() || request.auth.uid == userId;
      // Only admins can create or delete users through this rule.
      allow create, delete: if isAdmin();
    }
    
    // Rules for 'bank_cards'
    match /bank_cards/{cardId} {
      // Admins can read any card.
      // Teachers can read cards they own.
      allow read: if isAdmin() || (isTeacher() && resource.data.ownerId == request.auth.uid);
      // Teachers can create, update, and delete their own cards. Admins can manage any card.
      allow write: if isAdmin() || (isTeacher() && request.resource.data.ownerId == request.auth.uid);
    }

    // Rules for 'groups' and their subcollections
    match /groups/{groupId} {
      // Admins can read any group.
      // Teachers can read groups they are assigned to.
      // Students can read groups they are a member of.
      allow read: if isAdmin() 
                  || (isTeacher() && resource.data.teacherId == request.auth.uid)
                  || (isStudent() && request.auth.uid in resource.data.studentIds);
                  
      // Admins can create, update, delete any group.
      // Teachers can update groups they are assigned to.
      allow write: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);

      // Rules for 'lessons' subcollection
      match /lessons/{lessonId} {
        // Same read permissions as the parent group.
        allow read: if isAdmin()
                    || (isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid)
                    || (isStudent() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds);
        
        // Admins or the assigned teacher can write to lessons.
        allow write: if isAdmin() 
                     || (isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid);
      }
    }
    
    // Rules for PQRS
    match /pqrs/{pqrsId} {
      // Only students can create PQRS messages.
      allow create: if isStudent();
      // Only the receiving teacher or an admin can read/manage them.
      allow read, update, delete: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }
  }
}
