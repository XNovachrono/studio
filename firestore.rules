
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and update their own profile.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
    }

    // Teachers can manage their own content banks.
    // The 'list' permission on the collection is needed for queries with 'where' clauses to work.
    // The more specific 'read'/'write' on the document ensures they can only access their own content.
    match /banks/{cardId} {
      allow list: if request.auth != null;
      allow read, create, update, delete: if request.auth.uid == request.resource.data.ownerId   // For creates
                                          || request.auth.uid == resource.data.ownerId; // For updates, reads, deletes
    }
    
    // Teachers can read groups they are assigned to. Students can read groups they are members of.
    match /groups/{groupId} {
      allow read: if request.auth.uid == resource.data.teacherId 
                  || request.auth.uid in resource.data.studentIds;

      // Teachers can read and write lessons for groups they are assigned to.
      match /lessons/{lessonId} {
         allow read, create, update, delete: if request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
      }
    }
  }
}
