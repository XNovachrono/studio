
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Regla general: Solo los usuarios que han iniciado sesión pueden leer o escribir.
    // La lógica específica de "quién es dueño de qué" se maneja en las consultas de la aplicación.
    // Esto resuelve los problemas de permisos al permitir que las consultas complejas se ejecuten.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
