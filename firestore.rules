rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth.uid != null;
    }

    match /users/{userId} {
      allow read, update, delete: if request.auth.uid == userId;
      allow create: if isSignedIn();
    }
    
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    match /groups/{groupId}/lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    match /pqrs/{pqrId} {
        allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
        allow create: if isSignedIn();
        allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /bank_cards/{cardId} {
        allow read: if isSignedIn();
        allow create, update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /student_notes/{noteId} {
      // Allow a user to read, update, or delete a specific note if they are the owner.
      allow read, update, delete: if request.auth.uid == resource.data.studentId;

      // Allow a user to create a note if they are setting themselves as the owner.
      allow create: if request.auth.uid == request.resource.data.studentId;

      // Allow a user to LIST their own notes, and only their own notes.
      // This rule requires that the client-side query includes a `where("studentId", "==", request.auth.uid)` filter.
      allow list: if request.auth.uid != null && request.query.where.studentId == request.auth.uid;
    }
  }
}
