
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- UTILITIES ---
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Check for custom claim `admin` to be true.
      return request.auth.token.admin == true;
    }

    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // --- COLLECTIONS ---

    // Users can only read and write to their own user document.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Any authenticated user can read groups, but only the assigned teacher or an admin can modify them.
    match /groups/{groupId} {
      allow read: if isAuth();
      allow write: if isRole('teacher') || isAdmin();

      // Lessons can be read by any authenticated user. Writing is restricted to teachers/admins.
      match /lessons/{lessonId} {
        allow read: if isAuth();
        allow write: if isRole('teacher') || isAdmin();
      }
    }
    
    // Bank cards can be read by any authenticated user. Only owners or admins can write.
    match /bank_cards/{cardId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
    }
    
    // PQRS can be read by admins. Students can create them, admins can delete them.
    match /pqrs/{messageId} {
      allow read, delete: if isAdmin();
      allow create: if isOwner(request.resource.data.studentId);
    }
    
    // Student notes can only be accessed by the student who owns them.
    match /student_notes/{noteId} {
      allow list: if isAuth() && request.query.where.studentId == request.auth.uid;
      allow read, write: if isAuth() && (isOwner(request.resource.data.studentId) || isOwner(resource.data.studentId));
    }
  }
}
