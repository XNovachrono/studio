
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth.uid != null;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == resource.data.teacherId;
    }

    match /groups/{groupId}/lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
    }

    match /student_notes/{noteId} {
      allow read: if isSignedIn();
      allow create: if request.auth.uid == request.resource.data.studentId;
      allow update, delete: if request.auth.uid == resource.data.studentId;
    }

    match /pqrs/{pqrsId} {
      allow read: if isSignedIn();
      allow create: if request.auth.uid == request.resource.data.studentId;
    }
    
    match /bank_cards/{cardId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == request.resource.data.ownerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
