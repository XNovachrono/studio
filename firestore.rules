
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth.uid != null;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.uid == resource.data.teacherId;
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
    }
    
    match /student_notes/{noteId} {
      // Allow list if the query is constrained to the user's own notes
      allow list: if request.auth.uid != null && request.query.where.studentId.value == request.auth.uid;
      // Allow get, update, delete on a specific document if the user is the owner
      allow get, update, delete: if request.auth.uid == resource.data.studentId;
      // Allow create if the new document's studentId matches the user's ID
      allow create: if request.auth.uid == request.resource.data.studentId;
    }
    
    match /pqrs/{pqrsId} {
        allow read: if isSignedIn();
        allow create: if request.auth.uid == request.resource.data.studentId;
        allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /bank_cards/{cardId} {
        allow read: if isSignedIn();
        allow write: if request.auth.uid == request.resource.data.ownerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
