rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get user role from their document
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    // Helper function to check if a user is an admin
    function isAdmin(userId) {
      return getUserRole(userId) == 'admin';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can read any user profile.
      // Authenticated users can read their own profile.
      allow read: if isAdmin(request.auth.uid) || request.auth.uid == userId;
      
      // Users can only create their own profile or update their own data.
      allow write: if request.auth.uid == userId;
    }

    // Rules for the 'groups' collection and its subcollections
    match /groups/{groupId} {
      // Admins can read any group.
      // Teachers can read groups they are assigned to.
      // Students can read groups they are a member of.
      allow read: if isAdmin(request.auth.uid) 
                  || resource.data.teacherId == request.auth.uid 
                  || request.auth.uid in resource.data.studentIds;

      // Only Admins or the assigned teacher can update a group's main data.
      allow update: if isAdmin(request.auth.uid) || resource.data.teacherId == request.auth.uid;
      
      // Only Admins can create or delete groups.
      allow create, delete: if isAdmin(request.auth.uid);

      // Rules for the 'lessons' subcollection within a group
      match /lessons/{lessonId} {
        // Read access mirrors the parent group's read access.
        allow read: if get(parent).data.teacherId == request.auth.uid 
                    || request.auth.uid in get(parent).data.studentIds
                    || isAdmin(request.auth.uid);
        
        // Only the assigned teacher or an admin can create/update lessons.
        allow write: if get(parent).data.teacherId == request.auth.uid || isAdmin(request.auth.uid);
      }
    }
    
    // Rules for the 'pqrs' collection
    match /pqrs/{pqrsId} {
      // Admins can read and delete any PQRS message.
      allow read, delete: if isAdmin(request.auth.uid);
      
      // Students can create PQRS messages.
      allow create: if getUserRole(request.auth.uid) == 'student';
    }

    // Rules for the 'bank_cards' collection (content banks)
    match /bank_cards/{cardId} {
        // Admins can read all bank cards.
        // Teachers can read their own bank cards.
        allow read: if isAdmin(request.auth.uid) || resource.data.ownerId == request.auth.uid;
        
        // Teachers and Admins can create, update, and delete their own bank cards.
        allow write: if isAdmin(request.auth.uid) || request.auth.uid == request.resource.data.ownerId;
    }
  }
}
