
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the 'banks' collection
    match /banks/{bankId} {
      // A user can create a card if they are the owner
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      // A user can read, update, or delete a card if they are the owner
      allow read, update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Allow a user to query the 'banks' collection only if they are filtering by their own ownerId
    match /banks/{document=**} {
       allow list: if request.auth != null && request.query.where.get("ownerId") == request.auth.uid;
    }

    // Rules for groups and lessons
    match /groups/{groupId} {
      // Allow read for any authenticated user (students need to read group info)
      allow read: if request.auth != null;
      // Allow write only for the assigned teacher
      allow write: if request.auth != null && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;

      // Lessons subcollection
      match /lessons/{lessonId} {
         // Allow read for any authenticated user (students need to read lessons)
         allow read: if request.auth != null;
         // Allow write only for the teacher of the parent group
         allow write: if request.auth != null && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
      }
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
