rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isSignedIn() {
      return request.auth.uid != null;
    }
  
    // USERS
    // Read: Any signed-in user can read user profiles (needed for various parts of the app).
    // Write: You can only write to your own user document.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;
    }

    // GROUPS
    // Read: Any signed-in user can read group data.
    // Write: Only the teacher of the group can write to it. Admins should get rights via a Cloud Function.
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
      
      // LESSONS
      match /lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
      }
    }

    // STUDENT NOTES
    // Read: Any signed-in user can read notes (app code filters by studentId).
    // Write: You can only write to a note if you are the owner.
    match /student_notes/{noteId} {
      allow read: if isSignedIn();
      allow create: if request.auth.uid == request.resource.data.studentId;
      allow update, delete: if request.auth.uid == resource.data.studentId;
    }

    // PQRS
    // Read: Any signed-in user can read PQRS messages.
    // Write: Any signed-in user can create a PQRS message.
    match /pqrs/{pqrId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Deletion should be an admin-only task, managed via Cloud Functions for safety.
      allow update, delete: if false; 
    }

    // BANK CARDS
    // Read: Any signed-in user can read bank cards.
    // Write: Any signed-in user can create/update/delete their own cards.
    match /bank_cards/{cardId} {
      allow read: if isSignedIn();
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth.uid == resource.data.ownerId;
    }
  }
}
