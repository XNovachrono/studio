rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /student_notes/{noteId} {
      // A user can create a note if the note's studentId matches their own uid.
      allow create: if request.auth.uid == request.resource.data.studentId;

      // A user can read, update, or delete a note if the note's studentId matches their own uid.
      allow read, update, delete: if request.auth.uid == resource.data.studentId;
    }
  }
}
