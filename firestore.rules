rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins can do anything
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Teachers can read all user/group data but only write to their own groups/content
    function isTeacher() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    match /{document=**} {
      allow read: if isSignedIn();
    }
    
    match /users/{userId} {
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /groups/{groupId} {
      allow write: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
      allow write: if isAdmin() || (isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid);
    }

    match /bank_cards/{cardId} {
      allow write: if isAdmin() || (isTeacher() && request.resource.data.ownerId == request.auth.uid);
    }
    
    match /student_notes/{noteId} {
      allow write: if request.resource.data.studentId == request.auth.uid;
    }

    match /pqrs/{pqrsId} {
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}
