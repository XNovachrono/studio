rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if a user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Users can read/update their own profile. For simplicity, allow any authenticated user to list users.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow update: if isOwner(userId);
    }
    
    // Students and Teachers can read group data they are part of. Only teachers can update.
    match /groups/{groupId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.studentIds || isOwner(resource.data.teacherId));
      allow update: if isAuthenticated() && isOwner(resource.data.teacherId);

      // Lessons can be read by group members, but only written by the teacher.
      match /lessons/{lessonId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds || isOwner(get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId));
        allow create, update: if isAuthenticated() && isOwner(get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId);
      }
    }
    
    // Bank cards can be read by any authenticated user, but only created/modified by the owner.
    match /bank_cards/{cardId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isOwner(request.resource.data.ownerId);
        allow update, delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }
    
    // PQRS can be read by involved teacher/admin, created by students.
    match /pqrs/{pqrId} {
        allow read: if isAuthenticated(); // For simplicity, admins/teachers will filter on the client.
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated(); // Allow admin to delete
    }

    // Student notes can only be managed by the owner.
    match /student_notes/{noteId} {
      allow create: if isAuthenticated() && isOwner(request.resource.data.studentId);
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.studentId);
    }
  }
}
