rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección 'student_notes'
    match /student_notes/{noteId} {
      // Un usuario solo puede leer sus propios apuntes.
      // La consulta del cliente DEBE incluir `where('studentId', '==', request.auth.uid)`.
      allow read: if request.auth.uid == resource.data.studentId;

      // Un usuario solo puede crear un apunte para sí mismo.
      allow create: if request.auth.uid == request.resource.data.studentId;

      // Un usuario solo puede actualizar sus propios apuntes.
      allow update: if request.auth.uid == resource.data.studentId;

      // Un usuario solo puede eliminar sus propios apuntes.
      allow delete: if request.auth.uid == resource.data.studentId;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
