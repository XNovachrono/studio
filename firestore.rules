
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Uncoverly App Rules

    // Users Collection
    // - Students can read/update their own profile.
    // - Teachers can read/update their own profile.
    // - Admins can read any profile.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      // Future rule for admin
      // allow get: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Groups Collection
    // - Students can read groups they are a member of.
    // - Teachers can read/update groups they are assigned to.
    // - Admins can read any group.
    match /groups/{groupId} {
      allow read: if request.auth.uid in resource.data.studentIds || request.auth.uid == resource.data.teacherId;
      allow update: if request.auth.uid == resource.data.teacherId;

      // Lessons Subcollection
      // - Students can read lessons in their group.
      // - Teachers can create/update lessons in their group.
      match /lessons/{lessonId} {
        allow read: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds;
        allow create, update: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
      }
    }
    
    // Bank Cards Collection
    // - Any authenticated user can read cards (they are templates).
    // - Only the owner or an admin can create/update/delete.
    match /bank_cards/{cardId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == request.resource.data.ownerId;
        allow update, delete: if request.auth.uid == resource.data.ownerId;
        // Future rule for admin
        // allow update, delete: if request.auth.uid == resource.data.ownerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // PQRS Collection
    // - Students can create PQRS.
    // - The assigned teacher can read it.
    // - Admins can read/delete any PQRS.
    match /pqrs/{pqrsId} {
      allow create: if request.auth.uid == request.resource.data.studentId;
      allow read: if request.auth.uid == resource.data.teacherId;
      // Future rule for admin
      // allow read, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Student Notes Collection
    // - A user can only C/R/U/D their own notes.
    match /student_notes/{noteId} {
        allow create: if request.auth.uid == request.resource.data.studentId;
        allow read, update, delete: if request.auth.uid == resource.data.studentId;
    }
  }
}
