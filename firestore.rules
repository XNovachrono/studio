rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth.uid != null;
    }

    match /users/{userId} {
      // Any authenticated user can read user profiles.
      // The application code is responsible for filtering what is displayed.
      allow read: if isSignedIn();

      // A user can only write to their own profile.
      // Admin write access should be handled via a secure backend (e.g., Cloud Functions).
      allow write: if request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    match /groups/{groupId}/lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
    
    match /student_notes/{noteId} {
      allow read: if isSignedIn();
      // Only the owner of the note can create, update, or delete it.
      allow write: if request.auth.uid == request.resource.data.studentId;
    }

    match /pqrs/{pqrsId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /bank_cards/{cardId} {
        allow read: if isSignedIn();
        allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
  }
}
