rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'admin';
    }

    function isTeacher() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'teacher';
    }
    
    function isStudent() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'student';
    }
    
    function isTeacherOfGroup(groupId) {
      let group = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return isTeacher() && group.teacherId == request.auth.uid;
    }

    function isStudentInGroup(groupId) {
        let group = get(/databases/$(database)/documents/groups/$(groupId)).data;
        return isStudent() && request.auth.uid in group.studentIds;
    }
    
    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if isAdmin() || isUser(userId)
                    || (isTeacher() && get(/databases/$(database)/documents/users/$(userId)).data.role == 'student');
      
      allow create: if isSignedIn(); // Allow any signed-in user to create their profile
      
      allow update: if isUser(userId) || isAdmin() 
                      || (isTeacher() && request.resource.data.keys().hasOnly(['teacherInteractions']));
                      
      allow delete: if isAdmin();
    }

    // Rules for 'groups' collection and its subcollections
    match /groups/{groupId} {
      allow read: if isAdmin() || isTeacherOfGroup(groupId) || isStudentInGroup(groupId);
      allow create: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin() || isTeacherOfGroup(groupId);

      // Rules for 'lessons' subcollection
      match /lessons/{lessonId} {
        allow read: if isAdmin() || isTeacherOfGroup(groupId) || isStudentInGroup(groupId);
        allow create, update, delete: if isAdmin() || isTeacherOfGroup(groupId);
      }
    }
    
    // Rules for 'bank_cards' collection
    match /bank_cards/{cardId} {
        allow read: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
        allow create: if isAdmin() || isTeacher();
        allow update, delete: if isAdmin() || (isTeacher() && resource.data.ownerId == request.auth.uid);
    }
    
    // Rules for 'pqrs' collection
    match /pqrs/{pqrsId} {
      allow create: if isStudent();
      allow read: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }
  }
}
