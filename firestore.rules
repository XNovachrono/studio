rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: Anyone can read profiles (needed for names, etc.), but only the user can update their own profile.
    match /users/{userId} {
      allow read;
      allow update: if request.auth.uid == userId;
    }

    // Groups: Members (students or the teacher) can read. Only the teacher can update.
    // The 'list' permission is crucial for teachers/admins to query their groups.
    match /groups/{groupId} {
      allow read: if request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.studentIds;
      allow list: if request.auth.token.role == 'admin' || (request.auth.token.role == 'teacher' && request.query.filters.exists(f => f.field == 'teacherId' && f.value == request.auth.uid));
      allow update: if request.auth.uid == resource.data.teacherId;
    }

    // Lessons: Inherit read from group, only teacher can write.
    match /groups/{groupId}/lessons/{lessonId} {
      allow read: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds;
      allow create, update: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
    }

    // Student Notes: Only the owner can do anything.
    match /student_notes/{noteId} {
      allow read, write, delete: if request.auth.uid == resource.data.studentId;
      allow create: if request.auth.uid == request.resource.data.studentId;
    }
    
    // PQRS: Students can create. Teacher of the PQRS and the student who sent it can read. Admin can delete.
    match /pqrs/{pqrsId} {
        allow create: if request.auth.token.role == 'student';
        allow read: if request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.teacherId;
        allow delete: if request.auth.token.role == 'admin';
    }

    // Bank Cards: Any authenticated user can read/list, but only the owner or an admin can create, update, or delete.
    match /bank_cards/{cardId} {
        allow read, list;
        allow create, update, delete: if request.auth.uid == request.resource.data.ownerId || request.auth.token.role == 'admin';
    }
  }
}