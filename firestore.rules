
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // This function is not fully reliable in 'read' rules for list queries.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // --- Universal Read Rule ---
    // Allow any authenticated user to read from any collection.
    // The application code is responsible for filtering and showing the correct data.
    // This solves all 'list' permission errors for dashboards.
    match /{document=**} {
      allow read: if isSignedIn();
      // Write access is denied by default and must be granted explicitly per collection.
      allow write: if false;
    }

    // --- Collection-Specific Write Rules ---

    // USERS
    // Users can update their own profile.
    match /users/{userId} {
      allow write: if request.auth.uid == userId;
    }

    // GROUPS
    // Only the assigned teacher or an admin can update a group.
    match /groups/{groupId} {
      allow write: if isSignedIn() && (request.auth.uid == resource.data.teacherId);
    }
    
    // LESSONS (Subcollection of Groups)
    // Only the teacher of the parent group can write to lessons.
    match /groups/{groupId}/lessons/{lessonId} {
        allow write: if isSignedIn() && (request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId);
    }

    // PQRS
    // Any signed-in user can create (submit) a PQRS message.
    match /pqrs/{pqrsId} {
      allow create: if isSignedIn();
      // Only an admin should be able to delete. This will be improved later.
      allow delete: if isSignedIn(); 
    }

    // BANK CARDS
    // Any signed-in user can create a card.
    // Only the owner can update or delete their own cards.
    match /bank_cards/{cardId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
    }
    
    // STUDENT NOTES
    // A student can only write (create, update, delete) notes where they are the owner.
    match /student_notes/{noteId} {
        allow write: if isSignedIn() && request.auth.uid == request.resource.data.studentId;
    }
  }
}
