
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regla para la colección de usuarios
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reglas para la colección de bancos de contenido
    match /banks/{cardId} {
      // Permite la lectura de la colección para que las consultas con 'where' funcionen
      allow list: if request.auth != null;
      // Permite el acceso a un documento específico solo si el usuario es el propietario
      allow get, create, update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Reglas para la colección de grupos y sus lecciones
    match /groups/{groupId} {
      allow read, write: if request.auth != null && resource.data.teacherId == request.auth.uid;

      match /lessons/{lessonId} {
        allow read, write: if request.auth != null; // Se hereda la restricción del grupo
      }
    }
  }
}
