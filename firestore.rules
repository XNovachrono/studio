
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for user profiles
    match /users/{userId} {
      // Users can read their own profile and admins can read any profile.
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Users can only write to their own profile.
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the banks of content
    match /bank_cards/{cardId} {
      // A user can read, update, or delete a card if they are the owner.
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
      // A user can create a card if the ownerId in the new card is their own user ID.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Rules for groups and their subcollections (lessons)
    match /groups/{groupId} {
      // Allow read/write for the assigned teacher or an admin.
      allow read, write: if request.auth != null && 
                          (request.auth.uid == resource.data.teacherId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      // Rules for lessons within a group
      match /lessons/{lessonId} {
        // Inherit permissions from the parent group: only the teacher or an admin can manage lessons.
        allow read, write: if request.auth != null &&
                            (request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      }
    }

    // Fallback rule: deny all other access by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
