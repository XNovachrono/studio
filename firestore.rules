
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Banks: Teachers/Admins can only manage their own cards.
    match /banks/{bankId} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow write: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
    }

    match /banks/{bankId} {
        allow list: if request.auth != null && request.query.get('ownerId') == request.auth.uid;
    }

    // Users: Users can read their own profile, admins can read all.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Groups & Lessons: Only the assigned teacher can manage lessons.
    // Students in the group can read them.
    match /groups/{groupId} {
      allow read: if request.auth != null && (resource.data.teacherId == request.auth.uid || request.auth.uid in resource.data.studentIds);

      match /lessons/{lessonId} {
        allow read: if request.auth != null && (get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds);
        allow write: if request.auth != null && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
