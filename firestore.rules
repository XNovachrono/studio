
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Universal read access for any signed-in user.
    // Security is enforced by strict write rules and application logic.
    match /{document=**} {
      allow read: if isSignedIn();
    }

    // Specific write rules per collection
    match /users/{userId} {
      // A user can only write to their own document. Admins need a cloud function for elevated privileges.
      allow write: if request.auth.uid == userId;
    }

    match /groups/{groupId} {
      // The assigned teacher can write to the group.
      allow write: if request.auth.uid == resource.data.teacherId || request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
    }

    match /bank_cards/{cardId} {
      // Any signed-in user can create a card, but only the owner can update or delete it.
      allow create: if isSignedIn();
      allow update, delete: if request.auth.uid == resource.data.ownerId;
    }

    match /pqrs/{pqrsId} {
      // Any signed-in user can create a PQRS message.
      allow create: if isSignedIn();
      // Deletion is not allowed by default from client for security/auditing.
    }

    match /student_notes/{noteId} {
      // A user can create/update a note if the studentId in the new data is their own UID.
      allow create, update: if request.auth.uid == request.resource.data.studentId;
      // A user can delete a note if the studentId in the *existing* document is their own UID.
      allow delete: if request.auth.uid == resource.data.studentId;
    }
  }
}
