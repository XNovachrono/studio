
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile and admins can read any profile
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Groups can be read by assigned teacher or students in the group
    match /groups/{groupId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.studentIds);
      allow write: if request.auth != null && request.auth.uid == resource.data.teacherId;
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
       allow read: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds);
       allow write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
    }

    // Bank cards can only be accessed by their owner
    match /banks/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
