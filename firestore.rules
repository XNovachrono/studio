rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for security rules
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isStudent() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can read all user profiles.
      // Teachers can read their own profile and student profiles.
      // Students can read their own profile.
      allow read: if isAdmin() || 
                    (isTeacher() && (isOwner(userId) || resource.data.role == 'student')) ||
                    (isStudent() && isOwner(userId));
      
      // Students can update their own profile.
      // Admins can update any profile.
      allow write: if isAdmin() || isOwner(userId);
    }

    // Rules for the 'bank_cards' collection
    match /bank_cards/{cardId} {
      // Admins can read all cards.
      // Teachers can read their own cards.
      allow read: if isAdmin() || (isTeacher() && resource.data.ownerId == request.auth.uid);
      
      // Teachers can create, update, delete their own cards.
      // Admins can manage all cards.
      allow write: if isAdmin() || (isTeacher() && request.resource.data.ownerId == request.auth.uid);
    }

    // Rules for the 'groups' collection and its subcollections
    match /groups/{groupId} {
      // Admins can read all groups.
      // Teachers can read groups they are assigned to.
      // Students can read groups they are members of.
      allow read: if isAdmin() || 
                    (isTeacher() && resource.data.teacherId == request.auth.uid) ||
                    (isStudent() && request.auth.uid in resource.data.studentIds);
      
      // Only admins can create, update, or delete groups.
      allow write: if isAdmin();

      // Rules for the 'lessons' subcollection
      match /lessons/{lessonId} {
        // Same read rules as the parent group.
        allow read: if isAdmin() || 
                      (isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid) ||
                      (isStudent() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds);
        
        // Admins and the group's teacher can write to lessons.
        allow write: if isAdmin() || 
                       (isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid);
      }
    }
    
     // Rules for the 'pqrs' collection
    match /pqrs/{pqrsId} {
        // Only students can create PQRS messages.
      allow create: if isStudent();
      // Only the recipient teacher or an admin can read/delete them.
      allow read, delete: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }
  }
}
