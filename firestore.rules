rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check if the user is authenticated and if their user document shows they have the 'admin' role.
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS
    // Admins can read the full list of users and individual user profiles.
    // Authenticated users can read their own profile.
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
    }
    
    // GROUPS
    // Admins can manage all groups.
    // Teachers can read groups they are assigned to.
    // Students can read the group they are a member of.
    match /groups/{groupId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.studentIds;
      allow write: if isAdmin() || request.auth.uid == resource.data.teacherId;
    }
    
    // LESSONS (subcollection of GROUPS)
    match /groups/{groupId}/lessons/{lessonId} {
       allow read, write: if isAdmin() || request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds;
    }

    // PQRS
    // Admins can read all PQRS messages.
    // Teachers can read PQRS messages addressed to them.
    // Authenticated users can create PQRS messages.
    match /pqrs/{pqrId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.teacherId;
      allow create: if request.auth != null;
      allow delete: if isAdmin();
    }
    
    // BANK CARDS
    // Authenticated users (teachers/admins) can create cards.
    // Any authenticated user can read all cards (they are templates).
    // Only the owner or an admin can update/delete a card.
    match /bank_cards/{cardId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if isAdmin() || request.auth.uid == resource.data.ownerId;
    }

    // STUDENT NOTES
    // Students can manage their own notes.
    // Admins and the teacher of the student's group can read the notes.
    match /student_notes/{noteId} {
       allow read: if isOwner(resource.data.studentId) || isAdmin();
       allow write: if isOwner(resource.data.studentId);
    }

  }
}
