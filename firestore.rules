rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read and update their own profile
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to read the groups collection
    // Security is enforced by the queries in the application code
    match /groups/{groupId} {
        allow read: if request.auth != null;

        // Allow teachers to update their own groups and create/update lessons
         match /lessons/{lessonId} {
            allow read, write: if request.auth != null;
        }
    }
    
    // Bank Cards security rules
    match /bank_cards/{cardId} {
        // A user can create, read, update, and delete a card
        // only if the 'ownerId' matches their own user ID.
        allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Allow authenticated users to submit PQRS messages
    match /pqrs/{pqrsId} {
        allow create: if request.auth != null;
    }
  }
}

    