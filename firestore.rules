
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth.uid != null;
    }

    // --- USERS ---
    // Users can read any profile if they are signed in.
    // A user can only create or update their own profile.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if request.auth.uid == userId;
    }

    // --- GROUPS ---
    // Any signed-in user can read group data.
    // Only admins/teachers (handled by app logic) should update groups, so we restrict write access here.
    // For simplicity, we'll allow writes by signed-in users, assuming app logic prevents unauthorized writes.
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified for now, relies on app logic for teacher/admin roles.
    }

    // --- LESSONS (Subcollection of Groups) ---
    // Any signed-in user can read lessons.
    // Writes are simplified, relying on app logic for teacher roles.
    match /groups/{groupId}/lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
    }

    // --- STUDENT NOTES ---
    // Any signed-in user can read notes (app code filters by studentId).
    // Only the owner can write (create, update, delete) their own notes.
    match /student_notes/{noteId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.studentId == request.auth.uid;
    }
    
    // --- PQRS MESSAGES ---
    // Any signed-in user can read PQRS messages (app filters).
    // Any signed-in user can create a PQRS.
    // Deletion is restricted (e.g., to admins, handled by app logic).
    match /pqrs/{pqrId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isSignedIn(); // Simplified, relies on admin role check in app logic.
    }

    // --- BANK CARDS ---
    // Any signed-in user can read bank cards.
    // Any signed-in user can create/update/delete cards.
    match /bank_cards/{cardId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
    }
  }
}
