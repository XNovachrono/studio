
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas existentes...

    match /student_notes/{noteId} {
      // Permite leer, actualizar o borrar un apunte si el usuario es el propietario.
      allow read, update, delete: if request.auth.uid == resource.data.studentId;

      // Permite crear un apunte si el usuario que lo crea es el propietario.
      allow create: if request.auth.uid == request.resource.data.studentId;
    }

    // Regla para listar la colección de apuntes.
    match /student_notes/{document=**} {
        // Permite listar apuntes si la consulta filtra por el 'studentId' del usuario autenticado.
        // Esto es clave para que `getStudentNotes` funcione.
        allow list: if request.auth != null && request.query.filters.size() > 0 && 'studentId' in request.query.filters[0] && request.query.filters[0].studentId == request.auth.uid;
    }
  }
}
