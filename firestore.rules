
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for collections
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || get(resource.data).data.teacherId == request.auth.uid;
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
    }
    
    match /pqrs/{pqrsId} {
        allow create: if isSignedIn();
        allow read, delete: if isAdmin() || get(resource.data).data.teacherId == request.auth.uid;
    }

    match /bank_cards/{cardId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || resource.data.ownerId == request.auth.uid;
    }

    match /student_notes/{noteId} {
      // Students can only query for their own notes.
      allow list, get: if isSignedIn() && request.query.where.studentId == request.auth.uid;
      // Students can create, update, and delete their own notes.
      allow create, update, delete: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }
  }
}
