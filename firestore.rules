rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // --- Groups Collection ---
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
      
      // --- Lessons Subcollection ---
      match /lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
      }
    }
    
    // --- Student Notes Collection ---
    match /student_notes/{noteId} {
      allow read: if isSignedIn();
      // Only the student who owns the note can create, update, or delete it.
      allow create, update: if request.auth.uid == request.resource.data.studentId;
      allow delete: if request.auth.uid == resource.data.studentId;
    }
    
    // --- PQRS Collection ---
    match /pqrs/{pqrsId} {
        allow read: if isSignedIn();
        allow create: if isOwner(request.resource.data.studentId);
        allow delete: if isAdmin();
    }

    // --- Bank Cards Collection ---
    match /bank_cards/{cardId} {
        allow read: if isSignedIn();
        allow create: if isOwner(request.resource.data.ownerId);
        allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
    }
  }
}
