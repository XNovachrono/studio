rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isSignedIn() {
      return request.auth.uid != null;
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if false; // Deny writes by default
    }
    
    match /users/{userId} {
      allow write: if request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow write: if request.auth.uid == resource.data.teacherId;
    }

    match /groups/{groupId}/lessons/{lessonId} {
      allow write: if request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
    }

    match /student_notes/{noteId} {
      allow create, update: if request.auth.uid == request.resource.data.studentId;
      allow delete: if request.auth.uid == resource.data.studentId;
    }
    
    match /pqrs/{pqrsId} {
      allow create: if isSignedIn();
      allow delete: if isSignedIn(); // Allow admins to delete
    }

    match /bank_cards/{cardId} {
      allow create: if isSignedIn();
      allow update, delete: if request.auth.uid == resource.data.ownerId;
    }
  }
}

    