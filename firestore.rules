rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can read any profile if signed in.
    // Users can only create and update their own profile.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if request.auth.uid == userId;
      // Deleting users should be handled by an admin function, not allowed from client.
      allow delete: if false;
    }

    // Students can read their own notes and list them.
    // They can only write (create, update, delete) their own notes.
    match /student_notes/{noteId} {
        allow read: if isSignedIn();
        allow write: if request.auth.uid == request.resource.data.studentId;
    }

    // Groups can be read by any signed-in user.
    // Writing to groups is restricted.
    match /groups/{groupId} {
      allow read: if isSignedIn();
      // Only teachers or admins should update groups. This rule assumes teacherId is on the group.
      allow update: if isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
      allow create: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow delete: if false; // Groups should be archived, not deleted from client.

        // Lessons are subcollections of groups
        match /lessons/{lessonId} {
            allow read: if isSignedIn();
            allow write: if isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
        }
    }
    
    // Bank cards can be read by any signed-in user.
    // Only teachers and admins can create/update them.
    // Delete only if owner or admin.
    match /bank_cards/{cardId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
        allow delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // PQRS can be created by students. Admins can read/delete them.
    match /pqrs/{pqrId} {
      allow read: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}