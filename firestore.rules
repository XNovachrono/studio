
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow reading all user profiles, but only allow users to update their own.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Allow admins to read all groups.
    // Allow teachers to read groups they are assigned to.
    // Allow students to read groups they are in.
    match /groups/{groupId} {
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.uid == resource.data.teacherId;
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
       allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
    }

    // Allow authenticated users to create PQRS messages.
    // Allow admins and the involved teacher to read them.
    match /pqrs/{pqrId} {
      allow create: if request.auth != null;
      allow read, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.uid == resource.data.teacherId;
    }
    
    // Bank cards can be read by any authenticated user, but only created/updated/deleted by the owner or an admin.
    match /bank_cards/{cardId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == request.resource.data.ownerId;
        allow update, delete: if request.auth.uid == resource.data.ownerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Students can only read and write their own notes.
    match /student_notes/{noteId} {
      allow get, write: if request.auth.uid == resource.data.studentId;
      allow list: if request.query.resource.data.studentId == request.auth.uid;
    }
  }
}
