rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isTeacher() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
    function isStudent() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // USERS COLLECTION
    match /users/{userId} {
      // Admins can manage any user profile
      allow read, write: if isAdmin();
      // Users can read and update their own profile
      allow get, update: if isOwner(userId);
       // Teachers can read student profiles to get group member info
      allow read: if isTeacher() && resource.data.role == 'student';
    }
    
    // GROUPS COLLECTION
    match /groups/{groupId} {
       // Admins and authenticated users can read group lists (app logic filters).
      allow read: if isAuth();
      // Teachers can read groups they are assigned to.
      allow get: if isTeacher() && resource.data.teacherId == request.auth.uid;
      // Admins and assigned teachers can update groups (e.g., add content).
      allow update: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
      
      // LESSONS SUBCOLLECTION
      match /lessons/{lessonId} {
        // Admins can manage all lessons
        allow read, create, update: if isAdmin();
        // Teachers can manage lessons within their own groups
        allow read, create, update: if isTeacher() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
        // Students can read lessons of groups they belong to
        allow read: if isStudent() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds;
      }
    }

    // BANK CARDS COLLECTION
    match /bank_cards/{cardId} {
        // Admins can read all cards
        allow read: if isAdmin();
        // Teachers/Admins can manage their own cards
        allow read, create, update, delete: if isAuth() && (isAdmin() || (isTeacher() && request.resource.data.ownerId == request.auth.uid));
        // When updating/deleting, must be the owner.
        allow update, delete: if isAuth() && (isAdmin() || (isTeacher() && resource.data.ownerId == request.auth.uid));
    }

    // PQRS COLLECTION
    match /pqrs/{pqrsId} {
        // Admins can read and delete all PQRS messages
        allow read, delete: if isAdmin();
        // Students can create (submit) new PQRS messages
        allow create: if isStudent();
    }
  }
}
