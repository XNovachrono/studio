rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones de ayuda
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * @description Reglas para la colección de Usuarios.
     * Permite a los dueños leer/escribir su perfil. Permite a los admins listar y leer todos.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Reglas para la colección de Grupos.
     * Los usuarios autenticados pueden listar/leer grupos (la seguridad se refuerza en el código con filtros).
     */
    match /groups/{groupId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.teacherId);
      allow delete: if isAdmin();

      // Sub-colección de Lecciones
      match /lessons/{lessonId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid);

        // Sub-colección de Entregas de Tareas
        match /homework_submissions/{submissionId} {
          allow list: if isSignedIn();
          allow get: if isSignedIn();
          allow create: if isSignedIn() && request.auth.uid == request.resource.data.studentId;
          allow update: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.studentId || get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid));
          allow delete: if isAdmin();
        }
      }
    }

    /**
     * @description Reglas para PQRS.
     * Cualquier estudiante puede crear. Solo los admins pueden listar y gestionar.
     */
    match /pqrs/{pqrsId} {
      allow create: if isSignedIn();
      allow get, list, delete: if isAdmin();
    }

    /**
     * @description Reglas para Apuntes de Estudiantes.
     * Los estudiantes gestionan sus propios apuntes. Los admins pueden listar por supervisión.
     */
    match /student_notes/{noteId} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.studentId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.studentId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.studentId;
      allow list: if isAdmin();
    }

    /**
     * @description Reglas para Bancos de Contenido.
     * Todos los usuarios pueden ver el contenido. Solo dueños y admins pueden editar/borrar.
     */
    match /bank_cards/{cardId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.ownerId);
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.ownerId);
    }
  }
}