
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(resource) {
      return request.auth.uid == resource.data.ownerId;
    }
    
    // Users can read their own profile and admins can read any profile
    match /users/{userId} {
      allow read: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if request.auth.uid == userId;
    }
    
    // Authenticated users can read groups they are part of (either as teacher or student)
    match /groups/{groupId} {
      allow read: if request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.studentIds;
      // Only the assigned teacher can write to the group document
      allow write: if request.auth.uid == resource.data.teacherId;
    }

    // Lessons can be read by group members and written by the teacher
    match /groups/{groupId}/lessons/{lessonId} {
       allow read: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds;
       allow write: if get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
    }

    // Bank cards can be created by any authenticated user.
    // They can only be read, updated, or deleted by their owner.
    match /banks/{cardId} {
      allow read, update, delete: if isOwner(resource);
      allow create: if request.auth.uid != null && isOwner(request.resource);
    }
  }
}
