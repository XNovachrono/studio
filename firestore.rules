{
  "rules": {
    "databases": {
      "database": {
        "documents": {
          
          // --- Helper Functions ---
          function isSignedIn() {
            return request.auth.uid != null;
          }

          function isOwner(userId) {
            return request.auth.uid == userId;
          }

          function getRole() {
            return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
          }

          function isAdmin() {
            return getRole() == 'admin';
          }
          
          function isTeacher() {
            return getRole() == 'teacher';
          }

          // --- Collections ---

          match "/users/{userId}" {
            // READ: Anyone signed in can read user profiles.
            // This is needed for admins to list users and teachers to see student data.
            // App logic handles showing the correct data to the correct user.
            allow read: if isSignedIn();

            // WRITE: You can write to your own profile, or if you are an admin.
            allow write: if isOwner(userId) || isAdmin();
          }

          match "/groups/{groupId}" {
            // READ: Anyone signed in can read group data.
            allow read: if isSignedIn();
            
            // WRITE: Only admins or the teacher assigned to the group can write.
            allow write: if isAdmin() || isOwner(resource.data.teacherId);
          }
          
          match "/groups/{groupId}/lessons/{lessonId}" {
             // READ: Anyone signed in can read lessons.
             allow read: if isSignedIn();
             
             // WRITE: Only admins or the teacher of the parent group can write.
             allow write: if isAdmin() || isOwner(get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId);
          }

          match "/pqrs/{messageId}" {
            // READ: Admins and the involved teacher can read.
            allow read: if isAdmin() || isOwner(resource.data.teacherId);
            
            // CREATE: Any signed-in user can create one.
            allow create: if isSignedIn();
            
            // DELETE: Only admins can delete.
            allow delete: if isAdmin();
          }
          
          match "/bank_cards/{cardId}" {
             // READ: Any signed-in teacher or admin can read all bank cards.
             allow read: if isTeacher() || isAdmin();
             
             // WRITE: You can only write/delete your own cards, or if you are an admin.
             allow write: if isOwner(request.resource.data.ownerId) || (resource != null && isOwner(resource.data.ownerId)) || isAdmin();
          }

          match "/student_notes/{noteId}" {
            // READ: You can only read your own notes. The query in the app filters by studentId.
            allow read: if isSignedIn();

            // WRITE: You can only write/delete your own notes.
            allow write: if (request.resource.data.studentId == request.auth.uid) || (resource != null && resource.data.studentId == request.auth.uid);
          }
        }
      }
    }
  }
}
