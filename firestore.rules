rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
    function isInGroup(groupId) {
      let group = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return request.auth.uid in group.studentIds || request.auth.uid == group.teacherId;
    }

    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      allow update: if isAuth() && (isOwner(userId) || isAdmin());
      allow list: if isAuth() && isAdmin(); // Only admin can list all users
    }

    // Rules for 'groups' collection
    match /groups/{groupId} {
      allow read: if isAuth() && (isInGroup(groupId) || isAdmin());
      allow update: if isAuth() && (
        request.auth.uid == resource.data.teacherId || // Current teacher can update
        isAdmin() // Admin can update
      );
      allow create: if isAuth() && (isTeacher() || isAdmin());
      allow delete: if isAuth() && isAdmin();
      
      // Rules for 'lessons' subcollection
      match /lessons/{lessonId} {
        allow read: if isAuth() && (isInGroup(groupId) || isAdmin());
        allow create, update: if isAuth() && (
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId ||
          isAdmin()
        );
      }
    }
    
    // Rules for 'student_notes' collection
    match /student_notes/{noteId} {
        allow create: if isAuth() && isOwner(request.resource.data.studentId);
        allow read, update, delete: if isAuth() && isOwner(resource.data.studentId);
    }
    
    // Rules for 'bank_cards' collection
    match /bank_cards/{cardId} {
        allow read: if isAuth(); // Any authenticated user can read cards
        allow create: if isAuth() && (isTeacher() || isAdmin());
        allow update, delete: if isAuth() && (isOwner(resource.data.ownerId) || isAdmin());
    }

    // Rules for 'pqrs' collection
    match /pqrs/{pqrsId} {
      allow read: if isAuth() && (isOwner(resource.data.studentId) || resource.data.teacherId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow delete: if isAuth() && isAdmin();
    }
  }
}
