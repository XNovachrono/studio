rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified: logic is in backend. Admins/teachers can write.
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
        allow read, write: if isSignedIn(); // Simplified: Teachers/admins need this.
    }

    match /student_notes/{noteId} {
      allow read: if isSignedIn();
      allow write: if request.resource.data.studentId == request.auth.uid;
    }

    match /pqrs/{pqrsId} {
      allow read: if isSignedIn();
      allow create: if request.resource.data.studentId == request.auth.uid;
      allow delete: if isSignedIn(); // Simplified for admin
    }

    match /bank_cards/{cardId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Teachers and admins can write
    }
  }
}
