
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can read and write any user profile
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Users can read and update their own profile
      allow get, update: if isOwner(userId);
    }
    
    // Rules for the 'groups' collection
    match /groups/{groupId} {
      // Admins can manage all groups
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Teachers can read the groups they are assigned to
      allow get: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' && resource.data.teacherId == request.auth.uid;
      
      // Teachers can update group objectives and content
      allow update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' && resource.data.teacherId == request.auth.uid;
    }
    
    // Rules for lessons subcollection
    match /groups/{groupId}/lessons/{lessonId} {
        // Admins can do anything
        allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
        
        // Teachers can manage lessons for their assigned groups
        allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;

        // Students can read lessons from their group
        allow get: if request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds;
    }
    
    // Rules for the 'bank_cards' collection
    match /bank_cards/{cardId} {
        // Admins can manage all bank cards
        allow read, write, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
        
        // Teachers can read all cards
        allow list, get: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
        
        // Teachers can create cards
        allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
        
        // Teachers can only update/delete their own cards
        allow update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' && isOwner(resource.data.ownerId);
    }
    
    // Rules for the 'pqrs' collection
    match /pqrs/{pqrsId} {
      // Admins can manage all PQRS messages
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Students can create PQRS messages
      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // Rules for the 'student_notes' collection
    match /student_notes/{noteId} {
      // A user can create a note only if they are the owner of that note.
      allow create: if request.auth.uid == request.resource.data.studentId;
      
      // A user can read, update, or delete a note only if they are the owner.
      // This rule applies to `get`, `list`, `update`, and `delete` operations.
      // For `list`, the client query MUST include `where('studentId', '==', request.auth.uid)`.
      allow read, update, delete: if request.auth.uid == resource.data.studentId;
    }
  }
}
