rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // --- Global Read Rule ---
    // Allow any authenticated user to read from any collection.
    // Write access is handled by specific rules below.
    match /{document=**} {
      allow read: if isSignedIn();
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Users can write to their own document
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Groups Collection ---
    match /groups/{groupId} {
      // Teachers can create and update groups, Admins can do anything
      allow write: if isSignedIn() && (request.auth.uid == resource.data.teacherId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Lessons Subcollection
      match /lessons/{lessonId} {
        // Teacher of the group can write to lessons
        allow write: if isSignedIn() && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
      }
    }
    
    // --- PQRS Collection ---
    match /pqrs/{pqrsId} {
        // Students can create messages, Admins can delete
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Bank Cards Collection ---
    match /bank_cards/{cardId} {
        // Teachers/Admins can create cards
        allow create: if isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
        // Only owner or admin can update/delete
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // --- Student Notes Collection ---
    match /student_notes/{noteId} {
      // A user can only write (create, update, delete) notes if their UID matches the studentId in the note.
      allow write: if isSignedIn() && request.auth.uid == request.resource.data.studentId;
      // Overriding the global read to be more specific for delete operations that need access to resource
      allow read, delete: if isSignedIn() && request.auth.uid == resource.data.studentId;
    }
  }
}
