rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Cualquier usuario autenticado puede leer perfiles (necesario para que los admins y profesores vean los datos de los estudiantes).
      allow read: if isSignedIn();
      // Solo puedes actualizar tu propio perfil. Los administradores necesitarían una función en la nube para editar a otros (más seguro).
      allow write: if request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      // Solo el profesor asignado o un administrador (verificando el rol del token, no con get()) puede escribir.
      // Por simplicidad y para evitar errores de 'get', permitiremos al profesor asignado.
      allow write: if isSignedIn() && (resource.data.teacherId == request.auth.uid);
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
      allow read, write: if isSignedIn(); // Hereda los permisos del grupo para simplificar.
    }

    match /pqrs/{pqrsId} {
      allow read, write: if isSignedIn(); // Permitir lectura a admins/profesores, y escritura a estudiantes.
    }

    match /bank_cards/{cardId} {
      allow read: if isSignedIn();
      // Solo el propietario puede crear o modificar.
      allow write: if request.auth.uid == request.resource.data.ownerId || (exists() && request.auth.uid == resource.data.ownerId);
    }

    match /student_notes/{noteId} {
      allow read: if isSignedIn();
      // Un usuario solo puede escribir (crear/actualizar/borrar) un apunte si es el dueño.
      allow write: if (request.auth.uid == request.resource.data.studentId) || (exists() && request.auth.uid == resource.data.studentId);
    }
  }
}
