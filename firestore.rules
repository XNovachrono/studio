rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
    }
    
    function getGroup(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }
    
    function isGroupMember(groupId) {
      let group = getGroup(groupId);
      return isAuth() && request.auth.uid in group.studentIds;
    }
    
    function isGroupTeacher(groupId) {
      let group = getGroup(groupId);
      return isAuth() && request.auth.uid == group.teacherId;
    }

    match /groups/{groupId} {
      allow read: if isAuth() && (isGroupMember(groupId) || isGroupTeacher(groupId));
      allow write: if isAuth() && isGroupTeacher(groupId);
    }
    
    match /groups/{groupId}/lessons/{lessonId} {
      allow read: if isAuth() && (isGroupMember(groupId) || isGroupTeacher(groupId));
      allow write: if isAuth() && isGroupTeacher(groupId);
    }

    match /groups/{groupId}/lessons/{lessonId}/homework_submissions/{submissionId} {
      allow read: if isAuth() && (isOwner(resource.data.studentId) || isGroupTeacher(groupId));
      allow create: if isAuth() && isOwner(request.resource.data.studentId);
      allow update: if isAuth() && (isOwner(request.resource.data.studentId) || isGroupTeacher(groupId));
    }
    
    match /pqrs/{pqrsId} {
      allow create: if isAuth();
      allow read, delete: if isAuth(); // Admin/teacher will filter on client
    }
    
    match /student_notes/{noteId} {
      allow read, write: if isAuth() && isOwner(resource.data.studentId);
      allow create: if isAuth() && isOwner(request.resource.data.studentId);
    }
    
    match /bank_cards/{cardId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == request.resource.data.ownerId;
        allow update, delete: if isAuth() && (request.auth.uid == resource.data.ownerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
  }
}
