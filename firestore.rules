rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get user role
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    // Helper function to check if a user is an admin
    function isAdmin(userId) {
      return getUserRole(userId) == 'admin';
    }
    
    // Helper function to check if a user is a teacher
    function isTeacher(userId) {
      return getUserRole(userId) == 'teacher';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can read all user profiles
      // Users can read and update their own profile
      allow read: if isAdmin(request.auth.uid) || request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      // Allow creation for any authenticated user (during sign-up)
      allow create: if request.auth.uid != null;
    }

    // Rules for the 'groups' collection and its subcollections
    match /groups/{groupId} {
      // Admins can manage all groups
      // Teachers can read groups they are assigned to
      // Students can read groups they are members of
      allow read: if isAdmin(request.auth.uid) 
                  || resource.data.teacherId == request.auth.uid
                  || request.auth.uid in resource.data.studentIds;

      // Admins can create/update/delete groups
      // Teachers can update groups they are assigned to (e.g., add content)
      allow write: if isAdmin(request.auth.uid) 
                   || (isTeacher(request.auth.uid) && resource.data.teacherId == request.auth.uid);

      // Rules for the 'lessons' subcollection
      match /lessons/{lessonId} {
        // Permissions inherit from the parent group:
        // Admins, the group's teacher, and the group's students can read lessons.
        allow read: if isAdmin(request.auth.uid) 
                    || get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid
                    || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds;
        
        // Admins and the group's teacher can write to lessons.
        allow write: if isAdmin(request.auth.uid) 
                     || (isTeacher(request.auth.uid) && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid);
      }
    }
    
    // Rules for the 'bank_cards' collection (for teachers' content banks)
    match /bank_cards/{cardId} {
      // Admins can read all bank cards for moderation/oversight
      // Users can read, create, update, and delete their own bank cards
      allow read: if isAdmin(request.auth.uid) || resource.data.ownerId == request.auth.uid;
      allow create, update, delete: if resource.data.ownerId == request.auth.uid;
    }
    
    // Rules for 'pqrs' collection
    match /pqrs/{pqrsId} {
      // Only authenticated users can create PQRS messages
      allow create: if request.auth.uid != null;
      // Reading/updating/deleting should be restricted to specific roles (e.g., admins) if needed
      // For now, keeping it simple.
    }
  }
}