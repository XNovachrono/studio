rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla Global: Permite leer a cualquier usuario autenticado.
    // La seguridad de escritura se maneja en reglas más específicas.
    match /{document=**} {
      allow read: if request.auth.uid != null;
    }

    match /users/{userId} {
      allow write: if request.auth.uid == userId;
    }
    
    match /groups/{groupId} {
      // El docente del grupo o un admin puede actualizar el grupo.
      allow write: if request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /groups/{groupId}/lessons/{lessonId} {
        // Solo el docente del grupo puede escribir en las lecciones.
        allow write: if request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
    }

    match /pqrs/{pqrsId} {
      // Solo los estudiantes pueden crear mensajes PQRS.
      allow create: if request.auth.uid == request.resource.data.studentId;
      // Solo los administradores pueden borrar mensajes PQRS.
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /bank_cards/{cardId} {
      // Cualquiera autenticado puede crear una tarjeta de banco.
      allow create: if request.auth.uid != null;
      // Solo el dueño o un admin pueden actualizar o borrar.
      allow update, delete: if request.auth.uid == resource.data.ownerId
                           || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /student_notes/{noteId} {
        // Un estudiante puede crear, actualizar y borrar sus propios apuntes.
        allow create, update, delete: if request.auth.uid == request.resource.data.studentId;
    }
  }
}
