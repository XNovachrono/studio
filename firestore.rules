
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for authenticated users
    function isSignedIn() {
      return request.auth.uid != null;
    }
    
    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // === USERS ===
    // Allow users to read any profile (for names, etc.)
    // Allow users to create their own profile and only update/delete their own
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if request.auth.uid == userId;
      allow update, delete: if request.auth.uid == userId;
    }
    
    // === GROUPS ===
    // Allow any authenticated user to read groups (for dashboards)
    // Only allow admins/teachers to write to groups (simplified for now)
    match /groups/{groupId} {
      allow read: if isSignedIn();
      // Write rule is simplified; in a real app, this would check for admin/teacher role.
      allow write: if isSignedIn(); 
    }
    
    // === LESSONS (Subcollection of Groups) ===
    // Inherits read from parent, allow teacher to write
     match /groups/{groupId}/lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    // === STUDENT NOTES ===
    // Allow any authenticated user to READ (the code filters by studentId)
    // ONLY allow a user to write/delete notes that belong to them.
    match /student_notes/{noteId} {
      allow read: if isSignedIn();
      allow create, update: if request.auth.uid == request.resource.data.studentId;
      allow delete: if request.auth.uid == resource.data.studentId;
    }
    
    // === PQRS ===
    // Allow students to create, and admins/teachers to read.
    match /pqrs/{pqrsId} {
        allow read: if isSignedIn();
        allow create: if request.auth.uid == request.resource.data.studentId;
        allow write: if isSignedIn(); // Allow admins to delete
    }

    // === BANK CARDS ===
    // Allow any authenticated user to read.
    // Allow users to create/update/delete their own cards.
    match /bank_cards/{cardId} {
        allow read: if isSignedIn();
        allow create: if request.auth.uid == request.resource.data.ownerId;
        allow update, delete: if request.auth.uid == resource.data.ownerId;
    }
  }
}
