rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la colección 'users'
    match /users/{userId} {
      // Un usuario solo puede leer o escribir sus propios datos
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Reglas para la colección 'banks'
    match /banks/{bankId} {
      // Un usuario autenticado puede leer sus propias tarjetas
      allow get: if request.auth != null && resource.data.ownerId == request.auth.uid;
      // Permite la consulta si el usuario está filtrando por su propio ID de propietario
      allow list: if request.auth != null && request.query.where.get("ownerId") == request.auth.uid;
      // Un usuario autenticado puede crear, actualizar o eliminar sus propias tarjetas
      allow create, update, delete: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
    }

    // Reglas para la colección 'groups' y sus subcolecciones
    match /groups/{groupId} {
      // Los profesores solo pueden leer grupos donde ellos son el 'teacherId'
      allow get, list: if request.auth != null && resource.data.teacherId == request.auth.uid;
      
      // Los profesores solo pueden actualizar grupos que ellos enseñan
      allow update: if request.auth != null && resource.data.teacherId == request.auth.uid;

      // Reglas para la subcolección 'lessons'
      match /lessons/{lessonId} {
        // Un profesor puede gestionar las lecciones de un grupo que enseña
        // Primero, verificamos que el documento del grupo exista y que el profesor sea el correcto
        allow read, write, create, delete: if request.auth != null && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
      }
    }
    
    // Regla predeterminada: Denegar todo lo demás para mayor seguridad
    match /{document=**} {
      allow read, write: if false;
    }
  }
}