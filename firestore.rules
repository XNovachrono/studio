
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId, resource) {
      return resource.data.ownerId == userId;
    }

    // Users can read their own profile, admins can read any profile
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Authenticated users can read the list of banks to perform queries.
    // However, they can only get, create, update, or delete specific documents they own.
    match /banks/{cardId} {
        allow list: if request.auth != null;
        allow get, update, delete: if request.auth != null && isOwner(request.auth.uid, resource);
        allow create: if request.auth != null && isOwner(request.auth.uid, request.resource);
    }
    
    // Teachers can read groups they are assigned to. Students can read groups they are in.
    match /groups/{groupId} {
        allow read: if request.auth != null && (resource.data.teacherId == request.auth.uid || request.auth.uid in resource.data.studentIds);
        allow write: if request.auth != null && resource.data.teacherId == request.auth.uid; // Only teachers can write to their groups
        
        // Rules for the lessons subcollection
        match /lessons/{lessonId} {
            // Teacher of the group and students in the group can read lessons.
            allow read: if request.auth != null && (get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.studentIds);
            // Only the teacher of the group can create, update, or delete lessons.
            allow write: if request.auth != null && get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
        }
    }

    // Default deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
