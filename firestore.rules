rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regla permisiva de lectura: si estás logueado, puedes leer las colecciones principales.
    // La seguridad se delega a las reglas de escritura.
    function isAuthenticated() {
      return request.auth != null;
    }
    
    match /{document=**} {
      allow read: if isAuthenticated();
    }

    // --- REGLAS DE ESCRITURA ESPECÍFICAS ---

    match /users/{userId} {
      // Un usuario solo puede crear su propio perfil y solo puede actualizarlo.
      allow write: if request.auth.uid == userId;
    }

    match /groups/{groupId} {
      // Solo el profesor del grupo puede actualizarlo (e.g., cambiar objetivos).
      allow update: if request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
    }

    match /groups/{groupId}/lessons/{lessonId} {
       // Solo el profesor del grupo puede crear o actualizar lecciones.
       allow write: if request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId;
    }

    match /pqrs/{pqrId} {
      // Cualquiera que esté logueado puede crear un PQRS. Nadie puede actualizarlos.
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /bank_cards/{cardId} {
      // Puedes crear tarjetas.
      allow create: if isAuthenticated();
      // Solo puedes actualizar/borrar las tarjetas que te pertenecen.
      allow update, delete: if request.auth.uid == resource.data.ownerId;
    }

    match /student_notes/{noteId} {
      // Reglas estrictas para los apuntes de los estudiantes.
      // Solo puedes crear un apunte para ti mismo.
      allow create: if request.auth.uid == request.resource.data.studentId;
      // Solo puedes leer, actualizar o borrar tus propios apuntes.
      allow read, update, delete: if request.auth.uid == resource.data.studentId;
    }
  }
}