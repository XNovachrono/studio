
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth.uid != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Allow read for authenticated users, but restrict writes.
    // App logic is responsible for showing correct data to users.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      // Allow write if user is the assigned teacher or an admin.
      allow write: if (isOwner(resource.data.teacherId) || isAdmin());
    }

    match /groups/{groupId}/lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || get(/databases/$(database)/documents/groups/$(groupId)).data.teacherId == request.auth.uid;
    }

    match /pqrs/{pqrId} {
       allow read: if isSignedIn();
       // Allow students to create, but only admins or the target teacher to read/delete.
       allow create: if isOwner(request.resource.data.studentId);
       allow delete: if isAdmin() || isOwner(resource.data.teacherId);
    }

    match /bank_cards/{cardId} {
        allow read: if isSignedIn();
        // Allow write if user is the owner or an admin.
        allow write: if isOwner(resource.data.ownerId) || isAdmin();
    }

    match /student_notes/{noteId} {
      allow read: if isSignedIn();
      // Students can only write to their own notes.
      allow write: if request.auth.uid == request.resource.data.studentId;
    }
  }
}
