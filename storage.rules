rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to anyone
    match /{allPaths=**} {
      allow read;
    }
    
    // Allow write access only to authenticated users
    // This allows teachers and admins to upload to the banks.
    // The path includes the user's ID, which adds a layer of organization.
    match /{userId}/{bankType}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
